{
  "name": "@mephisto5558/i18n",
  "version": "2.0.1",
  "description": "I18n package using flattened keys",
  "keywords": [
    "i18n",
    "internationalization",
    "l10n",
    "localization"
  ],
  "homepage": "https://github.com/Mephisto5558/I18n#readme",
  "bugs": {
    "url": "https://github.com/Mephisto5558/I18n/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mephisto5558/I18n.git"
  },
  "license": "MIT",
  "author": "Mephisto5558",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "!**/*.tsbuildinfo",
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p ./tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true });\"",
    "lint": "eslint . --cache --cache-location ./node_modules/.cache/eslint/ >eslint.log",
    "test": "echo \"Error: no test specified\"",
    "watch": "npm run build -- --watch"
  },
  "devDependencies": {
    "@mephisto5558/eslint-config": "latest",
    "@types/node": "20.x",
    "discord-api-types": "latest"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error",
      "version": ">=20.19.0"
    }
  }
}
